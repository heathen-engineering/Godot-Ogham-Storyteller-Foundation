[configuration]
entry_symbol = "foundation_ogham_init"
compatibility_minimum = 4.6

[libraries]

windows.debug.x86_64   = "res://addons/FoundationOgham/bin/libFoundationOgham.windows.debug.x86_64.dll"
windows.release.x86_64 = "res://addons/FoundationOgham/bin/libFoundationOgham.windows.release.x86_64.dll"

linux.debug.x86_64   = "res://addons/FoundationOgham/bin/libFoundationOgham.linux.debug.x86_64.so"
linux.release.x86_64 = "res://addons/FoundationOgham/bin/libFoundationOgham.linux.release.x86_64.so"

macos.debug.x86_64   = "res://addons/FoundationOgham/bin/libFoundationOgham.macos.debug.x86_64.dylib"
macos.release.x86_64 = "res://addons/FoundationOgham/bin/libFoundationOgham.macos.release.x86_64.dylib"
